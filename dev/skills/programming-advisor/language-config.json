  "detectionStrategy": {
    "primaryIndicator": "character-count-ratio",
    "minCharacterThreshold": 10,
    "thaiCharacterRatio": 0.3,
    "fallbackLanguage": "en",
    "keywordMatchWeight": 1.5,
    "characterCountWeight": 1.0
  },
  "responseConfig": {
    "maintainLanguageConsistency": true,
    "allowCodeLanguageMixing": true,
    "preserveUrlsAcrossLanguages": true,
    "localizeAllUILabels": true,
    "localizeTableHeaders": true,
    "codeCommentsFollowUserLanguage": true,
    "preserveEmojis": true
