      "examples": ["ตัวแปร", "ฟังก์ชัน"],
      "recommendation": "Use English naming in code, Thai in comments only"
    },
    "englishVariableNaming": {
      "examples": ["camelCase", "SCREAMING_SNAKE_CASE"],
      "recommendation": "Standard programming convention"
    }
  },
  "features": {
    "languageAutoDetection": {
